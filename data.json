      "desc": "DDL USER ATE",
      "packages": [
        "oracle"
      ],
      "script": "set heading off;\nset echo off;\nSet pages 999;\nset long 90000;\n\n--# Identa\nexec DBMS_METADATA.set_transform_param (DBMS_METADATA.session_transform, 'PRETTY', true);\n--# coloca o / e ; no final.\nexec dbms_metadata.set_transform_param (dbms_metadata.session_transform,'SQLTERMINATOR',true);\nselect dbms_metadata.get_ddl('USER','APDATA560') DDL from dual;\nselect dbms_metadata.get_granted_ddl('SYSTEM_GRANT','ATE') DDL from dual;\nselect dbms_metadata.get_granted_ddl('ROLE_GRANT','ATE') DDL from dual;\nselect dbms_metadata.get_granted_ddl('OBJECT_GRANT','ATE') DDL from dual;",
      "created": "2026-02-27T15:56:24.486Z",
      "_idx": 6
    },
