      "id": 1772207812491,
      "desc": "Verificar Sessões travadas",
      "packages": [
        "oracle"
      ],
      "script": "select inst_id,sid,serial#,username,status,module,to_char(logon_time,'DD-MON-YY HH24:MI:SS') LOGON,sql_id,lockwait,schemaname,osuser,machine,program,service_name\nfrom gv$session\nwhere status not like '%TIVE'\norder by module,username;",
